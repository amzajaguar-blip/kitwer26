{
  "name": "kitwer26-audit",
  "version": "1.0.0",
  "description": "Kitwer26 Autonomous Audit System — self-healing convergence engine",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --loader ts-node/esm src/main.ts",
    "dev": "tsx src/main.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bullmq": "^5.8.2",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.30.10",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.21.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": false,
          "tsconfig": "./tsconfig.test.json"
        }
      ]
    },
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
