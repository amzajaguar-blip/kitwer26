# ── Database (Supabase direct PostgreSQL connection) ──────────────────────────
# Use the "Direct connection" string from Supabase → Settings → Database
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ── Redis (BullMQ queue backend) ──────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://default:TOKEN@HOST:PORT
REDIS_URL=redis://localhost:6379

# ── Audit configuration ───────────────────────────────────────────────────────
# Maximum convergence loops before escalating to human
AUDIT_MAX_LOOPS=5

# Minimum improvement delta (%) to continue looping; below this = converged
AUDIT_MIN_DELTA_PCT=1

# Dry-run mode: set to "true" to skip writing fixes to DB
AUDIT_DRY_RUN=false

# ── Optional: log level ───────────────────────────────────────────────────────
LOG_LEVEL=info
